# DB variables
spring.application.name=rem
spring.datasource.url=jdbc:mysql://localhost:3306/rem_db
spring.datasource.username=rem123
spring.datasource.password=123456
# Enable migration automatically
spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto=update
# Global prefix
server.servlet.context-path=/api/v1
# jwt
jwt.expiration=3600000
jwt.secret=
# Gmail variables
spring.mail.host=
spring.mail.port=
spring.mail.username=
spring.mail.password=
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
# Twilio variables
twilio.account-sid=
twilio.auth-token=
twilio.phone-number=
# Vonage variables
vonage.api-secret=
vonage.api-key=
vonage.from=
# cloudinary
cloudinary.cloud-name=
cloudinary.api-key=
cloudinary.api-secret=
cloudinary.base-folder=rem-app
# resend
resend.api-key=
resend.email=